# ── Docker Compose environment ────────────────────────────────────────────────
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_PORT=8000
FRONTEND_PORT=3000
LOG_LEVEL=info
WORKERS=0                    # 0 = auto (2*CPU+1)

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your production frontend URL in production
CORS_ORIGINS=http://localhost:3000

# ── Frontend → Backend URL ────────────────────────────────────────────────────
# Inside Docker Compose, frontend reaches backend via service name
NEXT_PUBLIC_API_URL=http://backend:8000

# ── AI Provider Keys (server-side fallbacks — optional) ───────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
