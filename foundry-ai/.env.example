# ============================================
# Foundry AI — Environment Variables
# ============================================
# Copy this file to .env and fill in your keys

# --- LLM API Keys ---
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
GOOGLE_API_KEY=AIzaSyxxx
GROQ_API_KEY=gsk_xxx

# --- Database ---
DATABASE_URL=postgresql+asyncpg://foundry:foundry@localhost:5432/foundry_ai

# --- Temporal ---
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=foundry-ai
TEMPORAL_TASK_QUEUE=foundry-mvp-queue

# --- LiteLLM ---
LITELLM_LOG_LEVEL=INFO

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# --- General ---
LOG_LEVEL=INFO
ENV=development
