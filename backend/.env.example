# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info               # debug | info | warning | error

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ── Workers (production only) ─────────────────────────────────────────────────
# 0 = auto (2 * CPU + 1)
WORKERS=0

# ── AI Provider Keys (server-side fallbacks — optional) ───────────────────────
# Users can also supply keys via the UI; these are fallbacks only.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
